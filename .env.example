# JWT Secret для подписи токенов авторизации
# Сгенерируйте случайную строку: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# Resend API Key для отправки email
# Получите на https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@luxesegment.com

# SMS.ru API ID для отправки SMS
# Получите на https://sms.ru/?panel=api
SMSRU_API_ID=

# Node Environment
NODE_ENV=development
